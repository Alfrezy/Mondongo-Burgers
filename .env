# 🛠️ CONFIGURACIÓN DE DESARROLLO (FLASK)
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_APP=app/app.py

# 🗄️ CREDENCIALES DE LA BASE DE DATOS
DB_NAME=mondongo_db
DB_USER=Osiris_God
DB_PASSWORD=12345
DB_PORT=5432

# 🌐 HOST DE LA BASE DE DATOS (Cambia según dónde lo corras)
# Usa 'localhost' si corres Python directo en Windows conectado a DBeaver
# Usa 'mondongo-db-container' (o el nombre de tu servicio) si usas Docker Compose
DB_HOST=localhost